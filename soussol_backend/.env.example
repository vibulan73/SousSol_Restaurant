# Jack's Norwood - Backend Environment Variables
# Spring Boot reads these as OS environment variables
# On Windows: set each variable before running, or use your IDE's run configuration

# ─── Database ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jacksnorwood
DB_USERNAME=postgres
DB_PASSWORD=4321

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=JacksNorwoodSuperSecretKeyForJWTTokenGeneration2024MustBe256Bits1234
JWT_EXPIRATION=86400000

# ─── CORS ───────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Mail ───────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=cde@gmail.com
MAIL_PASSWORD=app_password_for_gmail

# ─── Restaurant ──────────────────────────────────────────────
# Email address that receives contact form submissions
RESTAURANT_EMAIL=abc@gmail.com

# ─── Spring Profile ──────────────────────────────────────────
# Use 'dev' locally (seeds sample data on first boot)
# Use 'prod' in production (skips DataInitializer)
SPRING_PROFILES_ACTIVE=prod
